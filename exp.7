vi) Triplets with Zero Sum
#include <algorithm>
using namespace std;

bool hasTriplet(int arr[], int n) {
    sort(arr, arr + n);

    for (int i = 0; i < n-2; i++) {
        int l = i+1, r = n-1;

        while (l < r) {
            int sum = arr[i] + arr[l] + arr[r];

            if (sum == 0) return true;
            else if (sum < 0) l++;
            else r--;
        }
    }
    return false;
}

