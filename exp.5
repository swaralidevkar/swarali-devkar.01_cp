i) Separate Chaining


#include <iostream>
#include <vector>
using namespace std;

int main() {
    int arr[] = {10, 20, 15, 7};
    int n = 4, hashSize = 5;

    vector<vector<int>> hashTable(hashSize);

    for (int i = 0; i < n; i++) {
        int index = arr[i] % hashSize;
        hashTable[index].push_back(arr[i]);
    }

    for (int i = 0; i < hashSize; i++) {
        cout << i << ": ";
        for (int x : hashTable[i])
            cout << x << " -> ";
        cout << "NULL\n";
    }
}


ii) Linear Probing
#include <iostream>
using namespace std;

int main() {
    int arr[] = {10, 20, 15, 7};
    int n = 4, size = 5;

    int hash[size];
    for (int i = 0; i < size; i++) hash[i] = -1;

    for (int i = 0; i < n; i++) {
        int index = arr[i] % size;

        while (hash[index] != -1) {
            index = (index + 1) % size;
        }

        hash[index] = arr[i];
    }

    for (int i = 0; i < size; i++)
        cout << i << " -> " << hash[i] << endl;
}


